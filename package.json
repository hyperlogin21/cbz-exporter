{
  "name": "tools-webcomic-png-zip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-pdfjs-worker": "node -e \"const fs=require('fs'); fs.cpSync('node_modules/pdfjs-dist/build/pdf.worker.min.mjs','public/pdf.worker.min.mjs'); fs.cpSync('node_modules/pdfjs-dist/build/pdf.min.mjs','public/pdf.min.mjs');\"",
    "predev": "npm run copy-pdfjs-worker",
    "prebuild": "npm run copy-pdfjs-worker",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.6.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.462.0",
    "next": "14.2.29",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.29",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
